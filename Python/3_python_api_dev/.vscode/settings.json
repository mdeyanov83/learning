{
    "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
    // "python.defaultInterpreterPath": "./.venv/bin/python",


    "python.terminal.activateEnvironment": true,  // conflicts with workspace setting if set to false and "[info] Not enabling terminal env var experiment in multiroot remote workspaces"

    "python.terminal.executeInFileDir": true,
    // "python.terminal.useEnvFile": false,  // default: false  // controls if variables from .env files are injected into terminals
    // Ensures Pylance looks for your local code correctly
    "python.analysis.extraPaths": [
        "."
    ],
    "python.analysis.typeCheckingMode": "basic",

    // Used by Python Environment Manager extension
    "python-envs.pythonProjects": [
        {
            "path": ".",
            "envManager": "ms-python.python:venv",
            "packageManager": "ms-python.python:pip"
        }
    ],

}
